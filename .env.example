# ── LLM Provider ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini          # gpt-4o for higher quality, gpt-4o-mini to save cost

# ── Alpaca (paper trading) ────────────────────────────────────────────────────
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ALPACA_BASE_URL=https://api.alpaca.markets   # live — DO NOT enable without review

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=...
# Free tier: 25 requests/day. yfinance is used as automatic fallback.
# A 15-second rate-limit delay is enforced between all AV calls.

# ── NewsAPI ───────────────────────────────────────────────────────────────────
NEWS_API_KEY=...
# Free tier: 100 requests/day, some sources have 24h delay.
# Top headlines endpoint is real-time even on free tier.

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis                   # use 'localhost' for local dev outside Docker
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                    # leave blank for local dev

# ── LangSmith (optional observability) ────────────────────────────────────────
LANGCHAIN_TRACING_V2=false         # set true to enable LangSmith tracing
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=invest-bot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Risk Controls ─────────────────────────────────────────────────────────────
MAX_POSITION_SIZE_USD=1000         # max dollars allocated per position
MAX_PORTFOLIO_RISK_PCT=0.02        # 2% of portfolio at risk per trade
STOP_LOSS_PCT=0.05                 # 5% stop-loss on bracket orders
MAX_DAILY_TRADES=10                # circuit breaker: max trades per day

# ── Scheduling ────────────────────────────────────────────────────────────────
CREW_RUN_INTERVAL_MINUTES=60       # how often the full pipeline fires
MEMORY_RESET_DAY=sunday            # weekday for weekly memory wipe
MEMORY_RESET_HOUR=2                # hour (UTC) to run reset

# ── Scraping ──────────────────────────────────────────────────────────────────
CAPITOL_TRADES_URL=https://www.capitoltrades.com/trades
SCRAPE_DELAY_SECONDS=3             # polite delay between page requests
PLAYWRIGHT_HEADLESS=true
